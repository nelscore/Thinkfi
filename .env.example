# Server
PORT=3000
NODE_ENV=development

# AI
# Leave blank in development to use the built-in offline finance advisor.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# JWT
# Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_EXPIRES_IN=7d

# Email / Nodemailer
# In development, if SMTP is left blank, OTP codes are printed in the server console.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="ThinkFi <your_gmail@gmail.com>"

# Production CORS
# ALLOWED_ORIGIN=https://yourdomain.com
